{
  "name": "@cowboylogic/cerebro-schema",
  "version": "0.1.0",
  "description": "Shared schema, TypeScript types, and validator for the Cerebro artifact catalog format",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "default": "./dist/validate.js"
    }
  },
  "files": [
    "dist/",
    "schema/",
    "docs/"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "watch": "tsc --watch"
  },
  "keywords": [
    "cerebro",
    "schema",
    "ai",
    "artifacts",
    "catalog"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~6.0.3"
  }
}
